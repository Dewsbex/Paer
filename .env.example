# Paer — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# Supabase
PUBLIC_SUPABASE_URL=https://moarpiqwynhuwxkfrzlr.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare (set in Workers/Pages dashboard, not locally)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# paer-poll-feeds Cloudflare Worker secrets
# Set via: wrangler secret put <NAME> (from workers/poll-feeds/)
# Shared with the Supabase poll-feeds Edge Function (x-cron-secret header).
# CRON_SECRET=
# Secret required for manual POST / trigger of the worker.
# WORKER_TRIGGER_SECRET=

# AI Providers (optional — user-provided keys)
# These are NOT required for core functionality
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=

# App
PUBLIC_APP_URL=https://paer.dewsbery.uk
ENVIRONMENT=development
