# Paer — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# Database
DATABASE_URL=postgresql://paer:paer_dev@localhost:5432/paer
POSTGRES_USER=paer
POSTGRES_PASSWORD=paer_dev
POSTGRES_DB=paer

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-random-string
MAGIC_LINK_SECRET=change-me-to-another-random-string

# Email (for magic links and newsletter ingestion)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@paer.app

# AI Providers (optional — user-provided keys)
# These are NOT required for core functionality
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=

# App
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
ENVIRONMENT=development
